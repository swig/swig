#######################################################################
# Makefile for Go test-suite
#######################################################################

# Use to print the commands 'go build' use during build
# GOBUILDDBG=-x
LANGUAGE	= go
GO		= @GO@
GOROOT		= @GOROOT@
GOMINVER	= @GOMINVER@
GO_CYGPATH	= @GO_CYGPATH@
CGO_CFLAGS	= @CGO_CFLAGS@
CGO_CXXFLAGS	= @CGO_CXXFLAGS@
CGO_CPPFLAGS	= @CGO_CPPFLAGS@
CGO_LDFLAGS	= @CGO_LDFLAGS@
GOFLAGS		= @GOFLAGS@
GO111MODULE	= @GO111MODULE@
GOPROXY		= @GOPROXY@
GOMODCACHE	= @GOMODCACHE@
host		= @host@
SCRIPTSUFFIX	= _runme.go
RUNME		= runme
SWIGTESTS	= swigtests

SO = @SO@

HAVE_CXX11   = @HAVE_CXX11@
HAVE_CXX14   = @HAVE_CXX14@
HAVE_CXX17   = @HAVE_CXX17@
HAVE_CXX20   = @HAVE_CXX20@
srcdir         = @srcdir@
top_srcdir     = @top_srcdir@
top_builddir   = @top_builddir@
abs_top_srcdir = @abs_top_srcdir@
BOOST_CPPFLAGS = @BOOST_CPPFLAGS@

export GOROOT GOFLAGS GO111MODULE GOPROXY GOMODCACHE
export CGO_CXXFLAGS+=$(CXXFLAGS)
export CGO_LDFLAGS+=$(LDFLAGS)
%.ctest: export CGO_CFLAGS+=$(CFLAGS)

FAILING_CPP_TESTS += \
	director_frob # TODO: need fix, issue #3398

CPP_TEST_CASES = \
	go_inout \
	go_director_inout

MULTI_CPP_TEST_CASES = \
	go_subdir_import

include $(srcdir)/../common.mk

INCLUDES = -I$(abs_top_srcdir)/$(EXAMPLES)/$(TEST_SUITE)

# Ensure testsuite remains free from SWIG warnings.
SWIGOPT += -Werror

.SUFFIXES: .cpptest .ctest .multicpptest

# Rules for the different types of tests
%.cpptest:
	$(setup)
	+$(swig_and_compile_cpp)
	$(run_testcase_cpp)

%.ctest:
	$(setup)
	+$(swig_and_compile_c)
	$(run_testcase)

%.multicpptest:
	$(setup)
	+for f in `cat $(top_srcdir)/$(EXAMPLES)/$(TEST_SUITE)/$*.list` ; do \
	  n=`printf "$$f" | tr -d '\r\n\t '`; \
	  $(call swig_and_compile_cpp_helper,$${n},'$(SWIGOPT)') GOMOD="$*"; \
	  if test -n "$$all"; then \
	    for m in $$all ; do \
	      if grep -q "^import \"$$n/$$m\"" "$*/$(SWIGTESTS)/$$n/$$n.go"; then \
	        (cd $*/$(SWIGTESTS)/$$n && \
	         sed -i -- "s%^import \"$$n/%import \"$(SWIGTESTS)/%" $$n.go && \
	         $(GO) mod edit -replace "$(SWIGTESTS)/$$m=../$$m" && \
	         $(GO) get "$(SWIGTESTS)/$$m" 2>/dev/null && \
	         $(GO) mod tidy 2>/dev/null); \
	      fi;\
	    done; \
	  fi; all="$$all $$n"; \
	done
	$(run_multi_testcase)

# This test is done manually, as the modules are located in special subfolders!
# Normal tests here, uses a predefined subtree structure unlike this test!
# Modules can be stored in any subfolder as long as each module
# uses a unique folder and all sources of the module together with the 'go.mod' are
# stored in that single folder. A module may use additional files like 'go.sum'.
# A proper 'mod edit -replace' map subfolder location to import module name
# for each module that uses imports!
# When using more than one local import, it is a good practice to use 'go get'
# to ensure the imports are mapped properly!
# Imported modules are not build directly.
# Application modules will download remote import modules and
# build all of the imported modules including local modules,
# in addition the the application itself.
go_subdir_import.multicpptest:
	$(setup)
	mkdir -p $*/$(SWIGTESTS)/testdir/$*/$(*)_c/testdir/$* \
	  $*/$(SWIGTESTS)/$(*)_b/testdir/$*  $*/$(SWIGTESTS)/testdir/$*/$(*)_c
	+for f in `cat $(top_srcdir)/$(EXAMPLES)/$(TEST_SUITE)/$*.list` ; do \
	  n=`printf "$$f" | tr -d '\r\n\t '`; \
	  $(call swig_and_compile_cpp_helper,$${n},'$(SWIGOPT)') GOMOD="$*"; \
	done
	cd $*/$(SWIGTESTS)/testdir/$*/$(*)_c && mv -f testdir/$*/$(*)_c* .
	cd $*/$(SWIGTESTS)/$(*)_b && mv -f testdir/$*/$(*)_b.go .
	cd $*/$(SWIGTESTS)/$(*)_a && \
	sed -i -- "s%^import \"$(*)_a/%import \"$(SWIGTESTS)/%" $(*)_a.go && \
	$(GO) mod edit -replace "$(SWIGTESTS)/testdir/$*/$(*)_b"="../$(*)_b" && \
	$(GO) mod edit -replace "$(SWIGTESTS)/testdir/$*/$(*)_c"="../testdir/$*/$(*)_c" && \
	$(GO) get "$(SWIGTESTS)/testdir/$*/$(*)_b" 2>/dev/null && \
	$(GO) get "$(SWIGTESTS)/testdir/$*/$(*)_c" 2>/dev/null && \
	$(GO) mod tidy 2>/dev/null
	mkdir -p "$*/$(RUNME)"
	cp "$(SCRIPTDIR)/$(SCRIPTPREFIX)$*$(SCRIPTSUFFIX)" "$*/$(RUNME)/$(RUNME).go"
	if test ! -f "$*/$(RUNME)/go.mod" ; then \
	  (cd "$*/$(RUNME)" && $(GO) mod init $(RUNME) 2>/dev/null && \
	   $(GO) mod edit -replace "$(SWIGTESTS)/testdir/$*/$(*)_b"="../$(SWIGTESTS)/$(*)_b" && \
	   $(GO) mod edit -replace "$(SWIGTESTS)/testdir/$*/$(*)_c"="../$(SWIGTESTS)/testdir/$*/$(*)_c" && \
	   $(GO) mod edit -replace "$(SWIGTESTS)/$(*)_a"="../$(SWIGTESTS)/$(*)_a" && \
	   $(GO) get "$(SWIGTESTS)/testdir/$*/$(*)_b" 2>/dev/null && \
	   $(GO) get "$(SWIGTESTS)/testdir/$*/$(*)_c" 2>/dev/null && \
	   $(GO) get "$(SWIGTESTS)/$(*)_a" 2>/dev/null && \
	   $(GO) mod tidy 2>/dev/null);\
	fi
	includes="$(INCLUDES) -I `pwd` "; \
	if test -n "$(GO_CYGPATH)"; then \
	  n_includes=''; \
	  includes="$$includes $(BOOST_CPPFLAGS)"; \
	  for n in $${includes//-I}; do \
	    if test -d "$$n"; then \
	      n_includes="$$n_includes -I `$(GO_CYGPATH) -w $$n`"; \
	    else \
	      n_includes="$$n_includes $$n"; \
	    fi; \
	  done; \
	  includes="$$n_includes"; \
	fi; \
	CGO_CPPFLAGS="$(CGO_CPPFLAGS) $(CPPFLAGS) $$includes"; \
	export CGO_CPPFLAGS; \
	(cd "$*/$(RUNME)" && $(COMPILETOOL) $(GO) build $(GOBUILDDBG) .); \
	stat=$$?; \
	if test $$stat -ne 0; then \
	  exit $$stat; \
	fi
	env LD_LIBRARY_PATH=.:$$LD_LIBRARY_PATH $(RUNTOOL) $*/$(RUNME)/$(RUNME)

# Runs the testcase.
run_testcase = \
	if test -f "$(SCRIPTDIR)/$(SCRIPTPREFIX)$*$(SCRIPTSUFFIX)"; then \
	  mkdir -p $(RUNME)/$*;\
	  cp "$(SCRIPTDIR)/$(SCRIPTPREFIX)$*$(SCRIPTSUFFIX)" "$(RUNME)/$*/$(RUNME).go"; \
	  includes="$(INCLUDES) -I `pwd` "; \
	  if test -n "$(GO_CYGPATH)"; then \
	    n_includes=''; \
	    for n in $${includes//-I}; do \
	      if test -d "$$n"; then \
	        n_includes="$$n_includes -I `$(GO_CYGPATH) -w $$n`"; \
	      else \
	        n_includes="$$n_includes $$n"; \
	      fi; \
	    done; \
	    includes="$$n_includes"; \
	  fi; \
	  CGO_CPPFLAGS="$(CGO_CPPFLAGS) $(CPPFLAGS) $$includes"; \
	  export CGO_CPPFLAGS; \
	  if test ! -f "$(RUNME)/$*/go.mod" ; then \
	    (cd "$(RUNME)/$*" && $(GO) mod init $(RUNME) 2>/dev/null && \
	     $(GO) mod edit -replace "$(SWIGTESTS)/$*=../../$(SWIGTESTS)/$*" && \
	     $(GO) mod tidy 2>/dev/null); \
	  fi; \
	  (cd "$(RUNME)/$*" && $(COMPILETOOL) $(GO) build $(GOBUILDDBG) .); \
	  stat=$$?; \
	  if test $$stat -ne 0; then \
	    exit $$stat; \
	  fi; \
	  env LD_LIBRARY_PATH=.:$$LD_LIBRARY_PATH $(RUNTOOL) $(RUNME)/$*/$(RUNME); \
	fi

run_testcase_cpp = \
	if test -f "$(SCRIPTDIR)/$(SCRIPTPREFIX)$*$(SCRIPTSUFFIX)"; then \
	  mkdir -p "$(RUNME)/$*"; \
	  cp "$(SCRIPTDIR)/$(SCRIPTPREFIX)$*$(SCRIPTSUFFIX)" "$(RUNME)/$*/$(RUNME).go"; \
	  includes="$(INCLUDES) -I `pwd` "; \
	  if test -n "$(GO_CYGPATH)"; then \
	    n_includes=''; \
	    includes="$$includes $(BOOST_CPPFLAGS)"; \
	    for n in $${includes//-I}; do \
	      if test -d "$$n"; then \
	        n_includes="$$n_includes -I `$(GO_CYGPATH) -w $$n`"; \
	      else \
	        n_includes="$$n_includes $$n"; \
	      fi; \
	    done; \
	    includes="$$n_includes"; \
	  fi; \
	  CGO_CPPFLAGS="$(CGO_CPPFLAGS) $(CPPFLAGS) $$includes"; \
	  export CGO_CPPFLAGS; \
	  if test ! -f "$(RUNME)/$*/go.mod" ; then \
	    (cd "$(RUNME)/$*" && $(GO) mod init $(RUNME) 2>/dev/null && \
	     $(GO) mod edit -replace "$(SWIGTESTS)/$*=../../$(SWIGTESTS)/$*" && \
	     $(GO) mod tidy 2>/dev/null); \
	  fi; \
	  (cd "$(RUNME)/$*" && $(COMPILETOOL) $(GO) build $(GOBUILDDBG) .); \
	  stat=$$?; \
	  if test $$stat -ne 0; then \
	    exit $$stat; \
	  fi; \
	  env LD_LIBRARY_PATH=.:$$LD_LIBRARY_PATH $(RUNTOOL) $(RUNME)/$*/$(RUNME); \
	fi

run_multi_testcase = \
	if test -f $(SCRIPTDIR)/$(SCRIPTPREFIX)$*$(SCRIPTSUFFIX); then \
	  mkdir -p "$*/$(RUNME)"; \
	  cp "$(SCRIPTDIR)/$(SCRIPTPREFIX)$*$(SCRIPTSUFFIX)" "$*/$(RUNME)/$(RUNME).go"; \
	  includes="$(INCLUDES) -I `pwd` "; \
	  if test -n "$(GO_CYGPATH)"; then \
	    n_includes=''; \
	    includes="$$includes $(BOOST_CPPFLAGS)"; \
	    for n in $${includes//-I}; do \
	      if test -d "$$n"; then \
	        n_includes="$$n_includes -I `$(GO_CYGPATH) -w $$n`"; \
	      else \
	        n_includes="$$n_includes $$n"; \
	      fi; \
	    done; \
	    includes="$$n_includes"; \
	  fi; \
	  CGO_CPPFLAGS="$(CGO_CPPFLAGS) $(CPPFLAGS) $$includes"; \
	  export CGO_CPPFLAGS; \
	  if test ! -f "$*/$(RUNME)/go.mod" ; then \
	    (cd "$*/$(RUNME)" && $(GO) mod init $(RUNME) 2>/dev/null; \
	     for n in ../$(SWIGTESTS)/*; do \
	       m="`basename $$n`" && \
	       $(GO) mod edit -replace "$(SWIGTESTS)/$$m=$$n" && \
	       $(GO) get "$(SWIGTESTS)/$$m" 2>/dev/null; \
	     done && $(GO) mod tidy 2>/dev/null);\
	  fi; \
	  (cd "$*/$(RUNME)" && $(COMPILETOOL) $(GO) build $(GOBUILDDBG) .); \
	  stat=$$?; \
	  if test $$stat -ne 0; then \
	    exit $$stat; \
	  fi; \
	  env LD_LIBRARY_PATH=.:$$LD_LIBRARY_PATH $(RUNTOOL) $*/$(RUNME)/$(RUNME); \
	fi

%.clean:
	@rm -rf $(SWIGTESTS) $(RUNME) $*

clean:
	$(MAKE) -f $(top_builddir)/$(EXAMPLES)/Makefile SRCDIR='$(SRCDIR)' go_clean
	rm -rf $(SWIGTESTS) $(RUNME) $(MULTI_CPP_TEST_CASES)
