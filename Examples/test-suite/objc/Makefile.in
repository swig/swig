#######################################################################
# Makefile for Objective-C test-suite
#######################################################################

LANGUAGE     = objc
OBJC	     = @OBJC@
SCRIPTSUFFIX = _runme.m
OBJCXXFLAGS  = @OBJCCFLAGS@
OBJCFLAGS    = @OBJCFLAGS@
OBJCINCLUDES = @OBJCINC@
OBJCLIBS     = @OBJCLIBS@
HAVE_CXX11   = @HAVE_CXX11@
HAVE_CXX14   = @HAVE_CXX14@
HAVE_CXX17   = @HAVE_CXX17@
HAVE_CXX20   = @HAVE_CXX20@
srcdir       = @srcdir@
top_srcdir   = @top_srcdir@
top_builddir = @top_builddir@

# Modern C++ functionality still under development in the experimental backend.
FAILING_CPP_TESTS += \
	cpp11_alternate_function_syntax \
	cpp11_assign_rvalue_reference \
	cpp11_brackets_expression \
	cpp11_default_delete \
	cpp11_directors \
	cpp11_move_only \
	cpp11_move_only_valuewrapper \
	cpp11_move_typemaps \
	cpp11_rvalue_reference \
	cpp11_rvalue_reference2 \
	cpp11_rvalue_reference3 \
	cpp11_rvalue_reference_move \
	cpp11_std_unique_ptr \
	cpp11_strongly_typed_enumerations \
	cpp11_template_pack \
	cpp11_variadic_function_templates \
	cpp11_variadic_templates \

include $(srcdir)/../common.mk

CPP_TEST_CASES += objc_director

# Rules for the different types of tests
%.cpptest:
	$(setup)
	+$(swig_and_compile_cpp)
	$(run_testcase)

%.ctest:
	$(setup)
	+$(swig_and_compile_c)
	$(run_testcase)

%.multicpptest:
	$(setup)
	+$(swig_and_compile_multi_cpp)
	$(run_testcase)


# Compiles Objective-C files then runs the testcase. A testcase is only run if
# a file is found which has _runme.m appended after the testcase name.
run_testcase = \
	if test -f $(srcdir)/$(SCRIPTPREFIX)$*$(SCRIPTSUFFIX); then \
	  $(COMPILETOOL) $(OBJC) $(OBJCINCLUDES) $(OBJCFLAGS) $(OBJCXXFLAGS) $(srcdir)/$(SCRIPTPREFIX)$*$(SCRIPTSUFFIX) $(OBJCLIBS) -L. -l$* -o $*_runme && \
	  env LD_LIBRARY_PATH=.:$$LD_LIBRARY_PATH DYLD_LIBRARY_PATH=.:$$DYLD_LIBRARY_PATH $(RUNTOOL) ./$*_runme; \
	fi

# Cleans the testcase
%.clean:
	@rm -f $*_wrap.* $*_proxy.* $*_runme
clean:
	$(MAKE) -f $(top_builddir)/$(EXAMPLES)/Makefile objc_clean
